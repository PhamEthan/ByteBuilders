generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]

}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  password     String

  role         UserRole @default(PATIENT)
  verified     Boolean    //User email verification bool. Updates to true after user has reset their temporary password.
  fullName     String?    // optional for now
  dateOfBirth  DateTime?  // optional for now
  calEvents    String[]   //Stores calendar event IDs associated with the user account.

  resetToken   String?    // optional for user password reset
  registerToken String?   //temporary, for initial registration

  appointments Appointment[]
  files        File[]      @relation("UserFiles")
  auditLogs    AuditLog[]  @relation("UserAuditLogs")

  assignedPatients User[] @relation("CaregiverPatients") // For caregivers: patients assigned to them
  caregivers User[] @relation("CaregiverPatients")       // For patients: caregivers assigned to them
}

model Appointment {
  id            Int      @id @default(autoincrement())

  startTime     DateTime
  endTime       DateTime
  
  status        AppointmentStatus @default(AVAILABLE)

  googleEventId String?  @unique  // 🔒 one DB appointment per Google event

  patientId     Int?
  patient       User?    @relation(fields: [patientId], references: [id])

  createdAt     DateTime @default(now())
}

enum UserRole {
  PATIENT
  ADMIN
  CAREGIVER
}

enum AppointmentStatus {
  AVAILABLE
  BOOKED
  CANCELLED
}

model File {
  id           Int      @id @default(autoincrement())
  name         String
  storedName   String
  path         String
  size         Int
  type         String
  category     String
  note         String?
  uploadDate   DateTime @default(now())
  uploader     User     @relation("UserFiles", fields: [uploaderId], references: [id])
  uploaderId   Int
  auditLogs    AuditLog[]  @relation("FileAuditLogs")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation("UserAuditLogs", fields: [userId], references: [id])
  userId    Int
  action    String
  file      File?    @relation("FileAuditLogs", fields: [fileId], references: [id])
  fileId    Int?
  timestamp DateTime @default(now())
}
